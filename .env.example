# Database (Neon Postgres)
DATABASE_URL=postgresql://<user>:<pass>@<neon-host>/collateral?sslmode=require
DATABASE_URL_TEST=postgresql://<user>:<pass>@<neon-host>/collateral_test?sslmode=require

# App
PORT=3000
# NODE_ENV is set automatically:
#   - "test" by npm test (via cross-env)
#   - "development" for npm run dev
#   - "production" for npm start

# Stripe
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# X (Twitter) API
X_API_BEARER_TOKEN=AAAA...
X_CLIENT_ID=your_client_id
X_CLIENT_SECRET=your_client_secret

# Worker Configuration
WORKER_SLEEP_MS=15000
WORKER_CONCURRENCY=1

# Local Development Only (DO NOT SET IN PRODUCTION)
# USE_MOCK_X=true
# SKIP_DELTA_FLOOR=true

# ── $CLTR Blockchain Deployment Allocations ──
DEPLOYER_PRIVATE_KEY="0x..." # Metamask private key of deployer wallet (requires gas)
FOUNDER_WALLET_ADDR="0x..."
FOUNDER_VESTING_ADDR="0x..."
TREASURY_MULTISIG_ADDR="0x..."
LIQUIDITY_WALLET_ADDR="0x..."
STRATEGIC_RECIPIENTS="0x..."
TEAM_RECIPIENTS="0x...,0x..." # Exactly 10 comma-separated addresses
