# API Configuration
# Leave blank to use localhost:3000, or set to production URL
VITE_API_BASE_URL=

# Stripe Configuration
# Get your publishable key from https://dashboard.stripe.com/apikeys
# Use pk_test_... for development, pk_live_... for production
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_YOUR_PUBLISHABLE_KEY_HERE

# Pre-Launch Mode
# Set to 'true' to show the pre-launch waitlist page instead of the full app
VITE_PRE_LAUNCH_MODE=false

# ── $CLTR Smart Contract Addresses (Robinhood Chain) ──
VITE_CLTR_TOKEN=
VITE_STAKING=
VITE_FOUNDER_VESTING=
VITE_TEAM_VESTING=
VITE_SETTLEMENT=

# Reown Project ID
VITE_REOWN_PROJECT_ID=1467417e2e8e9de7d8d21dfbc2ccf28e
VITE_ROBINHOOD_RPC_URL=https://rpc.mainnet.chain.robinhood.com
