{
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ES2022",
        "esModuleInterop": true,
        "skipLibCheck": true,
        "strict": false,
        "noImplicitAny": false,
        "noEmitOnError": false,
        "declaration": true,
        "resolveJsonModule": true,
        "sourceMap": true,
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "src/*"
            ]
        }
    },
    "include": [
        "src"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "src/telemetry.ts",
        "src/tracing.ts",
        "src/metrics.ts"
    ]
}